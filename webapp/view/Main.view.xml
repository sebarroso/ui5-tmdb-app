<mvc:View
    controllerName="demo.tmdb.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <App id="app">
        <pages>
            <Page title="🎬 Buscador de Películas de Sebarroso">
                <content>
                    <VBox class="sapUiMediumMargin">
                        <!-- <Button
                            text="🎬 El Top 50 de Sebarroso"
                            type="Emphasized"
                            press=".onNavTop50"
                            class="sapUiSmallMarginBottom"/> -->
                        <!-- Barra de búsqueda -->
                        <HBox alignItems="Center" width="{= ${device>/system/phone} ? '100%' : '30%' }" class="sapUiSmallMarginBottom">
                            <SearchField
                                id="searchField"
                                placeholder="Ej: Matrix, Esperando la carroza, Inception..."
                                search=".onSearch">
                                <layoutData>
                                    <FlexItemData growFactor="1"/>
                                </layoutData>
                            </SearchField>
                            <Button
                                text="Buscar"
                                type="Emphasized"
                                press=".onSearch"
                                class="sapUiSmallMarginBegin"/>
                        </HBox>

                        <!-- Mensaje de estado -->
                        <Text
                            text="{appState>/statusMessage}"
                            visible="{= !!${appState>/statusMessage} }"
                            class="sapUiSmallMarginBottom"/>

                        <!-- Spinner -->
                        <BusyIndicator
                            visible="{appState>/busy}"
                            size="1rem"
                            class="sapUiSmallMarginBottom"/>

                        <!-- Lista de resultados -->
                        <List
                            id="movieList"
                            items="{movies>/results}"
                            noDataText="Sin resultados"
                            mode="None"
                            itemPress=".onMovieSelect">
                            <CustomListItem type="Active">
                                <HBox alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                                    <Image
                                        src="{movies>posterUrl}"
                                        width="60px"
                                        height="90px"
                                        class="sapUiSmallMarginEnd"
                                        decorative="false"
                                        alt="{movies>title}"/>
                                    <VBox justifyContent="Center">
                                        <Title text="{movies>title}" level="H5"/>
                                        <Text text="{movies>release_date}" class="sapUiTinyMarginTop"/>
                                        <ObjectStatus
                                            text="{movies>vote_average} ⭐"
                                            state="Success"
                                            class="sapUiTinyMarginTop"/>
                                        <Text text="{movies>original_language}" class="sapUiTinyMarginTop"/>
                                    </VBox>
                                </HBox>
                            </CustomListItem>
                        </List>

                        <!-- Paginación -->
                        <HBox
                            justifyContent="Center"
                            class="sapUiMediumMarginTop"
                            visible="{appState>/showPaging}">
                            <Button
                                text="← Anterior"
                                press=".onPrevPage"
                                enabled="{= ${appState>/currentPage} > 1 }"/>
                            <Text
                                text="Página {appState>/currentPage} de {appState>/totalPages}"
                                class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>
                            <Button
                                text="Siguiente →"
                                press=".onNextPage"
                                enabled="{= ${appState>/currentPage} &lt; ${appState>/totalPages} }"/>
                        </HBox>

                    </VBox>
                </content>
                <footer>
                    <Bar>
                        <contentMiddle>
                            <Link
                                text="🎬 El Top 50 de Sebarroso"
                                press=".onNavTop50"
                                emphasized="true"/>
                              
                        </contentMiddle>
                        <contentRight>
                        <Link text="Disclaimer" press=".onDisclaimer"/>  
                        </contentRight>
                        
                    </Bar>
                </footer>
            </Page>
        </pages>
    </App>

</mvc:View>

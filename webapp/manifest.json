{
  "_version": "1.12.0",
  "sap.app": {
    "id": "demo.tmdb",
    "type": "application",
    "title": "Buscador de Películas",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "demo.tmdb.view.Main",
      "type": "XML",
      "async": true,
      "id": "Main"
    },
    "dependencies": {
      "minUI5Version": "1.98.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "demo.tmdb.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "demo.tmdb.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteMain",
          "pattern": "",
          "target": ["TargetMain"]
        },
        {
          "name": "RouteDetalle",
          "pattern": "detalle/{movieId}",
          "target": ["TargetDetalle"]
        },
        {
          "name": "RouteTop50",
          "pattern": "top50",
          "target": ["TargetTop50"]
      }
      ],
      "targets": {
        "TargetMain": {
          "viewType": "XML",
          "transition": "slide",
          "viewName": "Main"
        },
        "TargetDetalle": {
          "viewType": "XML",
          "transition": "slide",
          "viewName": "Detalle"
        },
        "TargetTop50": {
            "viewType": "XML",
            "transition": "slide",
            "viewName": "Top50"
        }
      }
    }
  }
}